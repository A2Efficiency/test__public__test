EnergyManagementSystem:Program, 
  BaseSys7or3b_SuppCoilHtg_Avail_Setter,	!- Name 
  SET LockoutSetPt = ( 35.000 - 32 ) * 5 / 9,	!- Convert lock-out temp from F to C 
  IF OutdoorDBTemp >= LockoutSetPt, 
  SET BaseSys7or3b_SuppCoilHtg_Avail = 0, 
  ELSE, 
  SET BaseSys7or3b_SuppCoilHtg_Avail = 1, 
  ENDIF; 

