 #define  RunFileName  MF88Unit_ISUP_CEXH-SZHP_CZ9 - ap
   repHdrL = "MF88 Individual Supply + Central Exhaust (SZHP)"
   runTitle = "MF88 Individual Supply + Central Exhaust (SZHP)  /  Proposed (PV-Batt only)  /  MF88Unit_ISUP_CEXH-SZHP_CZ9.cibd25x"
   wfName = "CA_Title24_2025_LOS-ANGELES-USC.epw"
   ebTolHour = 0.001
   ebTolDay = 0.001
   ebTolMon = 0.001
   ebTolSubHr = 0.001
   tol = 0.01                           // Endtest convergence tolerance for internal iteration in models
   jan1DOW = "THU"
   skyModel = "anisotropic"
   bldgAzm = 0
   dt = "YES"
   heatDsTDbO = 43.1                    // ḞF
   coolDsCond = "ClgDC_0p4pct_Aug"
   ventAvail = zonal
   nSubSteps = 6
   wuDays = 15
   awTrigSlr = 0.3
   anTolAbs = 0.03
   anTolRel = 0.003
   auszTol = 0.05
   awTrigT = 15
   awTrigH = 1

   IMPORTFILE   "EplusElecUseImportFile"  
      imFileName = "MF88Unit_ISUP_CEXH-SZHP_CZ9 - ap-pvb-cse-elecuse.csv"    // Name of (path &) file to read data from
      imTitle = "EplusElecUse"          // Title expected to be found on line 3 of the import file
      imFreq = "Hour"                   // Specifies the interval at which CSE reads from the import file
      imHeader = "Yes"                  // Indicates whether the import file include a 4 line header

   GAIN   "EplusElecUseGain"  
      gnMeter = "MtrElec"               // Meter that tracks internal gain
      gnEndUse = "User1"                // Internal gain enduse
      gnPower = 3412.14 * import( "EplusElecUseImportFile", "EplusTotalKWH" )    // Expression representing internal gain power, Btuh

 DELETE Report "eb"    // move from end of CSE file

DESCOND   "ClgDC_0p4pct_Aug"  
   dcDB = 92.7                          // Cooling design dry-bulb temperature, ḞF
   dcDay = Aug 21                       // Calendar date for this design cooling conditions
   dcMCDBR = 20.7                       // Coincident daily dry-bulb range, ḞF
   dcMCWB = 70.2                        // Coincident wet-bulb temperature, ḞF
   dcMCWBR = 7.8                        // Coincident daily wet-bulb range, ḞF
   dcTauB = 0.383                       // ASHRAE beam 'pseudo optical depth'
   dcTauD = 2.433                       // ASHRAE diffuse 'pseudo optical depth'
   dcWindSpeed = 2                      // Wind speed for design conditions, mph

METER   "MtrElec"  

PERFORMANCEMAP   "Heat Pump System - Res-htgperfmap"      // Single speed: Autosized / HSPF2 7.5

   PMGRIDAXIS   "Heat Pump System - Res-htgdbtaxis"  
      pmGXType = "DBT"
      pmGXValues = 0, 5, 17, 47
      pmGXRefValue = 47

   PMGRIDAXIS   "Heat Pump System - Res-htgspdaxis"  
      pmGXType = "Speed"
      pmGXValues = 1
      pmGXRefValue = 1

   PMLOOKUPDATA   "Heat Pump System - Res-htgcapdata"  
      pmLUType = "CapRat"
      pmLUValues = 0.414067,            // 0F
                   0.4764,              // 5F
                   0.626,               // 17F
                   1                    // 47F

   PMLOOKUPDATA   "Heat Pump System - Res-htgcopdata"  
      pmLUType = "COP"
      pmLUValues = 1.776497,            // 0F
                   1.97852,             // 5F
                   2.414382,            // 17F
                   3.273178             // 47F

PERFORMANCEMAP   "Heat Pump System - Res-clgperfmap"      // Single speed: Autosized / EER2 11.7 / SEER2 14.3

   PMGRIDAXIS   "Heat Pump System - Res-clgdbtaxis"  
      pmGXType = "DBT"
      pmGXValues = 40, 48, 82, 95, 125
      pmGXRefValue = 95

   PMGRIDAXIS   "Heat Pump System - Res-clgspdaxis"  
      pmGXType = "Speed"
      pmGXValues = 1
      pmGXRefValue = 1

   PMLOOKUPDATA   "Heat Pump System - Res-clgcapdata"  
      pmLUType = "CapRat"
      pmLUValues = 1.290231,            // 40F
                   1.24779,             // 48.0F
                   1.0686,              // 82F
                   1,                   // 95F
                   0.841692             // 125F

   PMLOOKUPDATA   "Heat Pump System - Res-clgcopdata"  
      pmLUType = "COP"
      pmLUValues = 10.541931,           // 40F
                   10.195166,           // 48.0F
                   4.36554,             // 82F
                   3.428933,            // 95F
                   2.105477             // 125F

DOAS   "doas-Res Central Exhaust (All Units)"  
   oaSupFanElecPwr = 0.35               // Fan input power per unit air flow (at design flow and pressure), W/cfm
   oaSupFanEndUse = "FANV"              // Enduse to apply fan energy usage to
   oaExhFanElecPwr = 0.302              // Fan input power per unit air flow (at design flow and pressure), W/cfm
   oaExhFanEndUse = "FANV"              // Enduse to exhaust fan energy usage to
   oaHXBypass = "No"                    // This field denotes whether the heat exchanger is locked out when economizer is operating.

PVARRAY   "PV Array-sim"  
   pvDCSysSize = 274.5                  // kW
   pvModuleType = "Standard"
   pvArrayType = "FixedOpenRack"
   pvTilt = 22.619884                   // deg
   pvAzm = 170                          // deg
   pvSIF = 2                            // frac
   pvInverterEff = 0.96                 // frac
   pvSysLosses = 0.1744                 // frac
   pvElecMtr = "MtrElec"

BATTERY   "Battery-sim"  
   btChgEff = 0.95
   btDschgEff = 0.95
   btMaxCap = 221.17                    // kWh
   btMaxChgPwr = 65.04                  // kW
   btMaxDschgPwr = 65.04                // kW
   btChgReq = select( $dsDay>0, 0,   $month>(1-1) && $month<(12+1) && $hour<19 && $hour>(11-1),-min(@BATTERY[ 1].loadSeen, 0), default -max( @BATTERY[ 1].loadSeen, 0))    // kW
   btMeter = "MtrElec"

EXPORT   "ExportElec"  
   exExportfile = "Primary"             // Name of EXPORTFILE to write simulation results to
   exType = "MTR"                       // Export type
   exFreq = "HOUR"                      // Time interval for generating rows of export data
   exMeter = "MtrElec"                  // Meter to report
   exBtuSf = 1000                       // Result scaling factor (1,000 reports kBtu)
   exDayBeg = Jan 1                     // initial day of export period
   exDayEnd = Dec 31                    // final day of export period


 RUN
