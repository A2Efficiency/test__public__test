RSYS   "rsys-F2 Res Zn E Court HVACSys"  
   rsType = "ASHPPM"                    // System type
   AUTOSIZE rsCapC
   AUTOSIZE rsCap47
   rsFxCapC = 1.2                       // Cooling sizing factor
   rsFChgC = 0.96                       // Refrigerant charge adjustment factor (for cooling)
   rsSEER = 15.052632                   // Cooling SEER
   rsVfPerTon = 350                     // CFM per Ton (default = 350)
   rsFanMotTy = "PSC"                   // Fan motor type
   rsFanPwrH = 0.45                     // Heating fan power.  Heating air flow is estimated based on a 50 ?F temperature rise.
   rsFanPwrC = 0.45                     // Cooling fan power.
   rsParElec = ($tdboHrAv < 50.) * (1.-@RSYSRes["rsys-F2 Res Zn E Court HVACSys"].prior.H.hrsOn) * max( 36000, @RSYS["rsys-F2 Res Zn E Court HVACSys"].capNomC ) * 11./12000.    // Parasitic electric use, W
   rsDefrostModel = "RevCycleAux"       // Modeling options for ASHP outdoor coil defrosting when 17°F < TDbO < 45°F
   rsFxCapH = 1.2                       // Heating sizing factor
   rsFChgH = 0.96                       // Refrigerant charge adjustment factor (for heating)
   rsHSPF = 8.823529                    // ratio of BTU heat output over the heating season to watt-hours of electricity used, ratio
   rsTypeAuxH = "Resistance"            // type of aux heating equipment
   rsCtrlAuxH = "Cycle"                 // aux heating equipment control
   rsCapAuxH = 130000                   // Auxiliary (backup) heating capacity, Btuh
   rsASHPLockOutT = 0                   // Temperature below which the ASHP compressor is disabled, °F
   rsCdH = 0.08                         // Heating cyclic degradation coefficient, ratio
   rsCdC = 0.08                         // Cooling cyclic degradation coefficient, ratio
   rsOAVType = "None"                   // OAV system type
   rsElecMtr = "MtrElec"                // Electric use meter
   rsFuelMtr = "MtrNatGas"              // Natural gas use meter
   rsPerfMapHtg = "Heat Pump System - Res-htgperfmap"    // Heating performance map, Single speed: Autosized / HSPF2 7.5
   rsPerfMapClg = "Heat Pump System - Res-clgperfmap"    // Cooling performance map, Single speed: Autosized / EER2 11.7 / SEER2 14.3

   DUCTSEG   "SupplyDuct-rsys-F2 Res Zn E Court HVACSys"  
