   znModel = "CZM"                      // Zone model (CNE, CSE, CZM, UZM)
   znArea = 1080                        // Zone area, ft2
   znVol = 9720                         // Zone volume, ft3
   znEaveZ = 49.7                       // Height of top of the wall in this zone above the ground, ft
   znCeilingHt = 9                      // Nominal zone ceiling height relative to zone floor (typically 8-10 ft), ft
   znFloorZ = 40.7                      // Nominal zone floor height relative to arbitrary 0 level, ft
