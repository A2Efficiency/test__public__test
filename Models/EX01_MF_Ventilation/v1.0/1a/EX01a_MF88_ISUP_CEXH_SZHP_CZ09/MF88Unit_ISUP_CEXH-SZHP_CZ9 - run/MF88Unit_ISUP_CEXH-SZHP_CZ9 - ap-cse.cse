   oaRaLeak = 0                         // Return air damper leakage to mixed air (default 0.1), frac
   ahSOLeak = 0                         // Supply duct leakage to outdoors, expressed as a fraction of supply fan design flow, frac
   ahROLeak = 0                         // Return duct leakage FROM outdoors, expressed as a fraction of supply fan design flow, frac
   ahSOLoss = 0                         // Supply duct loss/gain to the outdoors, frac
   ahROLoss = 0                         // Return duct loss/gain to the outdoors, frac

DOAS   "doas-Res Central Exhaust (All Units)"  
   oaSupFanElecPwr = 0.35               // Fan input power per unit air flow (at design flow and pressure), W/cfm
   oaSupFanMtr = "MtrElec"              // Name of meter, if any, to record energy used by supply fan (enduse = 'Fan')
   oaSupFanEndUse = "FANV"              // Enduse to apply fan energy usage to
   oaExhFanElecPwr = 0.302              // Fan input power per unit air flow (at design flow and pressure), W/cfm
   oaExhFanMtr = "MtrElec"              // Name of meter, if any, to record energy used by exhaust fan (enduse = 'Fan')
   oaExhFanEndUse = "FANV"              // Enduse to exhaust fan energy usage to
   oaHXBypass = "No"                    // This field denotes whether the heat exchanger is locked out when economizer is operating.

