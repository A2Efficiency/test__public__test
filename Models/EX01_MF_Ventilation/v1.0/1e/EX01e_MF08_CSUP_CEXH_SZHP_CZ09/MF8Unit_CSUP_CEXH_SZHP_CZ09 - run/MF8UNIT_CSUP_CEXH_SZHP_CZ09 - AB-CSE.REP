        ZONE   "Zone1-zn"  
           znModel = "CZM"                      // Zone model (CNE, CSE, CZM, UZM)
           znArea = 3660                        // Zone area, ft2
           znVol = 29280                        // Zone volume, ft3
           znEaveZ = 8.7                        // Height of top of the wall in this zone above the ground, ft
           znCeilingHt = 8                      // Nominal zone ceiling height relative to zone floor (typically 8-10 ft), ft
           znFloorZ = 0.7                       // Nominal zone floor height relative to arbitrary 0 level, ft
           znCAir = 7320                        // Zone 'air' heat capacity: represents heat capacity of air, furniture, 'light' walls, and everything in zone except nonQUICK surfaces
           znSC = select( $radDiff >1., 0.5, default 0.8 )    // Expression representing zone shade closure
           znTH = select( $dsDay==1, 70, $dsDay==2, 60, ISSEASONCOOLING, 60, default 68)     // Expression representing heating setpoint, °F
           znTC = select( $dsDay==1, 83, $dsDay==2, 75, default 78)    // Expression representing cooling setpoint, °F
           znTD = select( $dsDay==1, 77, $dsDay==2, 99, ISSEASONCOOLING, 68, default 77 )    // Expression representing desired setpoint, °F
           znHIRatio = 10                       // Zone hygric inertia ratio
           infAC = 0                            // Zone infiltration air changes per hour, 1/hr
           infELA = 0                           // Zone effective leakage area (ELA), in2
           infShld = 4                          // Zone local shielding class, used in ELA model
           znRSys = "rsys-Zone1 HVACSys"        // RSYS component conditioning this ZONE
        
           GAIN   "Zone1-znLtg"  
              gnMeter = "MtrElec"               // Meter that tracks internal gain
              gnEndUse = "Lit"                  // Internal gain enduse
              gnPower = 2.68089 * 3660 * select( $dsDay==1, 0., $ISWEHOL, IntLight_WEH, Default IntLight_WD) * Other_SM    // Expression representing internal gain power, Btuh
              gnFrRad = 0.2                     // Fraction of internal gain to Zone that is Radiant (single value or hourly profile)
        
           GAIN   "Zone1-znPpl"  
              gnPower = 17.4806 * 3660 * select( $dsDay==1, 0., default hourval(0.035,0.035,0.035,0.035,0.035,0.059,0.082,0.055,0.027,0.014,0.014,0.014,0.014,0.014,0.019,0.027,0.041,0.055,0.068,0.082,0.082,0.07,0.053,0.035)  * choose1($month, 1.19,1.11,1.02,0.93,0.84,0.8,0.82,0.88,0.98,1.07,1.16,1.21))    // Expression representing internal gain power, Btuh
              gnFrRad = 0.3                     // Fraction of internal gain to Zone that is Radiant (single value or hourly profile)
              gnFrLat = 0.427                   // Fraction of internal gain to Zone that is Latent (single value or hourly profile)
        
           GAIN   "Zone1-znTV"  
              gnMeter = "MtrElec"               // Meter that tracks internal gain
              gnEndUse = "Rcp"                  // Internal gain enduse
              gnPower = 11692.4 * select( $dsDay==1, 0., $ISWEHOL, TV_WEH, Default TV_WD) * TV_SM    // Expression representing internal gain power, Btuh
              gnFrRad = 0.4                     // Fraction of internal gain to Zone that is Radiant (single value or hourly profile)
        
           GAIN   "Zone1-znSTB"  
              gnMeter = "MtrElec"               // Meter that tracks internal gain
              gnEndUse = "Rcp"                  // Internal gain enduse
              gnPower = 6173.38 * select( $dsDay==1, 0., $ISWEHOL, STB_WEH, Default STB_WD) * STB_SM    // Expression representing internal gain power, Btuh
              gnFrRad = 0.2                     // Fraction of internal gain to Zone that is Radiant (single value or hourly profile)
        
           GAIN   "Zone1-znComp"  
              gnMeter = "MtrElec"               // Meter that tracks internal gain
              gnEndUse = "Rcp"                  // Internal gain enduse
              gnPower = 6061.21 * select( $dsDay==1, 0., $ISWEHOL, Comp_WEH, Default Comp_WD) * Comp_SM    // Expression representing internal gain power, Btuh
              gnFrRad = 0.2                     // Fraction of internal gain to Zone that is Radiant (single value or hourly profile)
        
           GAIN   "Zone1-znMEL"  
