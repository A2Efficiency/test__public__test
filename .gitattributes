# CBECC / EnergyPlus model output files — preserve exact byte content.
# These are generated by compliance software; line endings must not be
# converted by git or by any contributor's local settings.
*.cibd25x    -text
*.cibd25i    -text
*.xml        -text
*.csv        -text
*.CSV        -text
*.REP        -text
*.rep        -text
*.cse        -text
*.err        -text
*.ddy        -text
*.epw        -text
*.txt        -text
*.osm        -text
*.idf        -text
*.json       -text
*.log        -text
*.spl        -text
*.ibd-Detail            -text
*.ibd-b4Evals           -text
*.ibd-Detail-B4Eval     -text

# True binary formats — never diff, never convert.
*.pdf   -text -diff binary
*.xlsx  -text -diff binary

# Repo documentation and config — normal text, normalized to LF.
*.md            text eol=lf
.gitattributes  text eol=lf
.gitignore      text eol=lf
LICENSE         text eol=lf
